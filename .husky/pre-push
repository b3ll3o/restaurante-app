#!/bin/sh
# Pre-push hook para MenuLink
# Executa validações antes do push

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "🔍 Executando validações pre-push..."
echo "======================================"

# Chama script de validação
node scripts/validate-pre-push.js

RESULT=$?

echo ""
if [ $RESULT -eq 0 ]; then
    echo -e "${GREEN}✅ Validações OK - Push liberado${NC}"
    echo "======================================"
else
    echo -e "${RED}❌ Falha - Corrija os erros acima${NC}"
    echo "======================================"
fi

exit $RESULT